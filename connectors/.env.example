# Kafka Connect — Environment Variables
# Copy to .env on the Kafka Connect EC2 instance
# Secrets are injected at runtime from AWS Secrets Manager

# Kafka
KAFKA_BOOTSTRAP_SERVERS=10.0.2.119:9092,10.0.2.135:9092

# PostgreSQL (fetch from Secrets Manager at deploy time)
POSTGRES_HOST=<RDS_ENDPOINT>
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<FROM_SECRETS_MANAGER>

# S3
S3_BUCKET=iot-streaming-backup-528582359305
AWS_REGION=us-east-1

# Snowflake
SNOWFLAKE_URL=<account>.snowflakecomputing.com
SNOWFLAKE_USER=KAFKA_CONNECTOR
SNOWFLAKE_PRIVATE_KEY=<base64_private_key>

# Connect API
CONNECT_HOST=localhost
CONNECT_PORT=8083
