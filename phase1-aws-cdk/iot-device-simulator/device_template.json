{
  "typeId": "geo_sensor",
  "name": "IoT Geo/Telemetry Sensor",
  "topic": "iot/geo-events",
  "payload": [
    { "name": "device_id",     "type": "id" },
    { "name": "latitude",      "type": "location", "lat": 51.5030, "long": -0.0032, "radius": 0.01 },
    { "name": "longitude",     "type": "location_lng" },
    { "name": "aqi",           "type": "float", "min": 0, "max": 150 },
    { "name": "temperature_c", "type": "float", "min": 15, "max": 30 },
    { "name": "battery_pct",   "type": "float", "min": 20, "max": 100 },
    { "name": "timestamp",     "type": "timestamp" }
  ],
  "simulation": {
    "devicesInParallel": 5,
    "intervalSeconds": 2,
    "durationMinutes": 60
  },
  "iotCoreRule": {
    "ruleName": "route_geo_events_to_msk",
    "sql": "SELECT * FROM 'iot/geo-events'",
    "action": "kafka",
    "kafkaTopic": "iot-events",
    "mskClusterArn": "<fill in after MSK stack deploy>"
  }
}
