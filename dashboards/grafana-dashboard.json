      "type": "barchart",
      "datasource": {
        "type": "amazon-timestream",
        "uid": "timestream-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "amazon-timestream",
            "uid": "timestream-datasource"
          },
          "rawQuery": "SELECT region, anomaly_type, SUM(measure_value::bigint) as total FROM \"IoTStreamingDB\".\"anomaly_counts\" WHERE time > ago($__range) GROUP BY region, anomaly_type",
          "refId": "A"
        }
      ]
    }
