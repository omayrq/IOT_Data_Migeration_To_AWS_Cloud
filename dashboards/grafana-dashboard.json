      "id": 5,
      "title": "Device Temperature Trends",
      "type": "timeseries",
      "datasource": {
        "type": "amazon-timestream",
        "uid": "timestream-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "amazon-timestream",
            "uid": "timestream-datasource"
          },
          "rawQuery": "SELECT bin(time, 5m) as time, device_id, AVG(measure_value::double) as avg_temp FROM \"IoTStreamingDB\".\"device_telemetry\" WHERE measure_name = 'avg_temperature' AND time > ago($__range) GROUP BY bin(time, 5m), device_id ORDER BY time ASC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "celsius"
        }
      }
    ],
