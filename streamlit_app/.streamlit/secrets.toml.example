# Copy to .streamlit/secrets.toml and fill in your Snowflake credentials.
# Never commit the real secrets.toml to git.

[snowflake]
account = "xy12345.eu-west-2.aws"
user = "HACKATHON_SVC_USER"
password = "change-me"
role = "ANALYTICS_ROLE"
warehouse = "HACKATHON_WH"
database = "HACKATHON_IOT"
schema = "ANALYTICS"
